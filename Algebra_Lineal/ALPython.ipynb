"cells": [
  {
    "cell_type": "markdown",
    "metadata": {},
    "source": [
      "# Álgebra Lineal con Python\n",
      "\n",
      "Este notebook introduce conceptos básicos de álgebra lineal utilizando Python y NumPy.\n",
      "\n",
      "## Contenido\n",
      "- Operaciones básicas\n",
      "- Vectores\n",
      "- Matrices\n",
      "- Determinante\n",
      "- Matriz inversa\n",
      "- Eigenvalores y eigenvectores\n"
    ]
  },
  {
    "cell_type": "code",
    "execution_count": null,
    "metadata": {},
    "outputs": [],
    "source": [
      "# Operaciones básicas\n",
      "print(\"Operaciones básicas:\")\n",
      "print(\"1 + 1 =\", 1 + 1)\n",
      "print(\"3.5 - 2.6 =\", 3.5 - 2.6)\n",
      "print(\"2 * 3 =\", 2 * 3)\n",
      "print(\"2^3 =\", 2**3)\n",
      "print(\"4 / 3 =\", 4 / 3)\n"
    ]
  },
  {
    "cell_type": "code",
    "execution_count": null,
    "metadata": {},
    "outputs": [],
    "source": [
      "import numpy as np\n",
      "\n",
      "# Vectores\n",
      "vector_a = np.array([1, 2, 3])\n",
      "vector_b = np.array([4, 5, 6])\n",
      "\n",
      "print(\"Vector A:\", vector_a)\n",
      "print(\"Vector B:\", vector_b)\n",
      "print(\"Suma:\", vector_a + vector_b)\n",
      "print(\"Producto punto:\", np.dot(vector_a, vector_b))\n"
    ]
  },
  {
    "cell_type": "code",
    "execution_count": null,
    "metadata": {},
    "outputs": [],
    "source": [
      "# Matrices\n",
      "A = np.array([[1, 2], [3, 4]])\n",
      "B = np.array([[5, 6], [7, 8]])\n",
      "\n",
      "print(\"Matriz A:\\n\", A)\n",
      "print(\"Matriz B:\\n\", B)\n",
      "print(\"Suma:\\n\", A + B)\n",
      "print(\"Multiplicación:\\n\", np.dot(A, B))\n"
    ]
  },
  {
    "cell_type": "code",
    "execution_count": null,
    "metadata": {},
    "outputs": [],
    "source": [
      "# Determinante\n",
      "det_A = np.linalg.det(A)\n",
      "print(\"Determinante de A:\", det_A)\n"
    ]
  },
  {
    "cell_type": "code",
    "execution_count": null,
    "metadata": {},
    "outputs": [],
    "source": [
      "# Matriz inversa\n",
      "inv_A = np.linalg.inv(A)\n",
      "print(\"Inversa de A:\\n\", inv_A)\n"
    ]
  },
  {
    "cell_type": "code",
    "execution_count": null,
    "metadata": {},
    "outputs": [],
    "source": [
      "# Eigenvalores y eigenvectores\n",
      "eigenvalues, eigenvectors = np.linalg.eig(A)\n",
      "print(\"Eigenvalores:\", eigenvalues)\n",
      "print(\"Eigenvectores:\\n\", eigenvectors)\n"
    ]
  }
]
