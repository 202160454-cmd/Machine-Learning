# Instalación (solo si es necesario)
!pip install "pymongo[srv]"

from pymongo import MongoClient
import datetime
import pprint

# 🔐 Conexión segura (sin credenciales reales)
client = MongoClient("mongodb+srv://<username>:<password>@cluster3c.onauj.mongodb.net/myFirstDatabase?retryWrites=true&w=majority")

# Conexión a la base de datos
db = client.get_database("clients")

# Selección de colección
records = db.clients_records


# ----------------------------
# Inserción de un documento
# ----------------------------
new_clients = {
    "Name": "Xul",
    "roll_no": 321,
    "Subject": "Probability"
}

records.insert_one(new_clients)


# ----------------------------
# Inserción de múltiples documentos
# ----------------------------
new_clients = [
    {
        "Name": "Gal",
        "roll_no": 567,
        "Subject": "Calculus"
    },
    {
        "Name": "Clo",
        "roll_no": 912,
        "Subject": "Statistics"
    },
    {
        "Name": "Beta",
        "roll_no": 278,
        "Subject": "Literature"
    }
]

records.insert_many(new_clients)


# ----------------------------
# Consulta de datos
# ----------------------------
print("Todos los registros:")
pprint.pprint(list(records.find()))

print("\nRegistro específico:")
pprint.pprint(records.find_one({"roll_no": 321}))


# ----------------------------
# Actualización de datos
# ----------------------------
clients_updates = {
    "Name": "XulioZ"
}

records.update_one({"roll_no": 321}, {"$set": clients_updates})


# ----------------------------
# Eliminación de datos
# ----------------------------
records.delete_one({"roll_no": 912})


# ----------------------------
# Conteo de documentos
# ----------------------------
count = records.count_documents({})
print("\nTotal de documentos:", count)
